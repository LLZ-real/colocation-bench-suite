#!/usr/bin/env bash

# Repository and external dependencies. Defaults come from conf/env.sh when
# available.
export EXP_NAME="${EXP_NAME:-app_taobench_colocation}"
export RESULTS_ROOT="${RESULTS_ROOT:-/home/lilinzhen/colocate_lab/results/cbs}"

# Placement.
export SERVER_CPUSET="${SERVER_CPUSET:-0,2,4,6,8,10,12,14}"
export SERVER_MEMS="${SERVER_MEMS:-0}"
export LOADGEN_CPUSET="${LOADGEN_CPUSET:-1,3,5,7,9,11,13,15,33,35,37,39,41,43,45,47}"
export LOADGEN_MEMS="${LOADGEN_MEMS:-1}"
export OFFLINE_CPUSET="${OFFLINE_CPUSET:-16,18,20,22,24,26,28,30}"
export OFFLINE_MEMS="${OFFLINE_MEMS:-0}"

# Workload.
export OFFLINE_TYPE="${OFFLINE_TYPE:-none}"
export OFFLINE_PARAM="${OFFLINE_PARAM:-}"
export OFFLINE_LABEL="${OFFLINE_LABEL:-none}"
export SPEC_CONFIG="${SPEC_CONFIG:-my_test.cfg}"
export SPEC_SIZE="${SPEC_SIZE:-ref}"
export SPEC_COPIES="${SPEC_COPIES:-1}"

# TaoBench client/server.
export CLIENTS_PER_THREAD="${CLIENTS_PER_THREAD:-900}"
export CLIENT_WARMUP_TIME="${CLIENT_WARMUP_TIME:-120}"
export CLIENT_TEST_TIME="${CLIENT_TEST_TIME:-60}"
export TAO_SERVER_WARMUP_TIME="${TAO_SERVER_WARMUP_TIME:-2400}"
export TAO_SERVER_TEST_TIME="${TAO_SERVER_TEST_TIME:-10800}"
export SERVER_BOOTSTRAP_WAIT="${SERVER_BOOTSTRAP_WAIT:-180}"
export OFFLINE_STABILIZE_WAIT="${OFFLINE_STABILIZE_WAIT:-20}"

# Cgroup and Docker resource controls.
export CGROUP_MODE="${CGROUP_MODE:-docker}"
export SERVER_CGROUP_PARENT="${SERVER_CGROUP_PARENT:-}"
export LOADGEN_CGROUP_PARENT="${LOADGEN_CGROUP_PARENT:-}"
export OFFLINE_CGROUP_PARENT="${OFFLINE_CGROUP_PARENT:-}"
export SERVER_CPU_SHARES="${SERVER_CPU_SHARES:-}"
export LOADGEN_CPU_SHARES="${LOADGEN_CPU_SHARES:-}"
export OFFLINE_CPU_SHARES="${OFFLINE_CPU_SHARES:-}"
export SERVER_CPU_QUOTA="${SERVER_CPU_QUOTA:-}"
export LOADGEN_CPU_QUOTA="${LOADGEN_CPU_QUOTA:-}"
export OFFLINE_CPU_QUOTA="${OFFLINE_CPU_QUOTA:-}"
export SERVER_MEMORY_LIMIT="${SERVER_MEMORY_LIMIT:-}"
export LOADGEN_MEMORY_LIMIT="${LOADGEN_MEMORY_LIMIT:-}"
export OFFLINE_MEMORY_LIMIT="${OFFLINE_MEMORY_LIMIT:-}"
export SERVER_BLKIO_WEIGHT="${SERVER_BLKIO_WEIGHT:-}"
export LOADGEN_BLKIO_WEIGHT="${LOADGEN_BLKIO_WEIGHT:-}"
export OFFLINE_BLKIO_WEIGHT="${OFFLINE_BLKIO_WEIGHT:-}"
export OFFLINE_DEVICE_READ_BPS="${OFFLINE_DEVICE_READ_BPS:-}"
export OFFLINE_DEVICE_WRITE_BPS="${OFFLINE_DEVICE_WRITE_BPS:-}"

# Reserved resource hooks.
export RDT_ENABLE="${RDT_ENABLE:-0}"
export SERVER_LLC_MASK="${SERVER_LLC_MASK:-}"
export LOADGEN_LLC_MASK="${LOADGEN_LLC_MASK:-}"
export OFFLINE_LLC_MASK="${OFFLINE_LLC_MASK:-}"
export MBA_ENABLE="${MBA_ENABLE:-0}"
export SERVER_MBA_PERCENT="${SERVER_MBA_PERCENT:-}"
export LOADGEN_MBA_PERCENT="${LOADGEN_MBA_PERCENT:-}"
export OFFLINE_MBA_PERCENT="${OFFLINE_MBA_PERCENT:-}"
export NET_SHAPE_ENABLE="${NET_SHAPE_ENABLE:-0}"
export NET_IFACE="${NET_IFACE:-}"
export LOADGEN_NET_RATE="${LOADGEN_NET_RATE:-}"
export OFFLINE_NET_RATE="${OFFLINE_NET_RATE:-}"
export CPU_FREQ_ENABLE="${CPU_FREQ_ENABLE:-0}"
export CPU_FREQ_GOVERNOR="${CPU_FREQ_GOVERNOR:-}"
export CPU_FREQ_MIN="${CPU_FREQ_MIN:-}"
export CPU_FREQ_MAX="${CPU_FREQ_MAX:-}"

